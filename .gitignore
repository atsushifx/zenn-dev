##  General
#   OS specific files
.DS_Store
thumbs.db

#   logs, patches
*.log
*.diff
*.patch

#   history, cache
.history/
.cache/
# **/*cache


#   backup/swap/temp
$~*
~*
*~
*.tmp
*.swp
*.lock

# session files
*session.json
*session
**/*session.json
**/*session

# .env files
.env*
.env.*

# release
releases/*
!releases/.keep

##  Git
!**/.gitignore

## Development tools (installed locally)
.tools/

## Worktrees
# worktree base dir
.worktrees/

## AI generated files

## Coding AI depended
# SDD (Spec-Driven Development) files

# claude code setting
.claude/*

# settings
!.claude/**/settings.json

# agents can tracking
!**/CLAUDE*.md
!.claude/agents/
!.claude/agents/**
!.claude/rules/
!.claude/rules/**
!.claude/commands/
!.claude/commands/**

# MCP server dependency files
.cocoindex_code/
.serena/
.lsmcp/
.codegraph/*

## Temporary directories are never tracked
temp/
tmp/
**/temp/
**/tmp/

##  Editor
#   VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
!.vscode/cspell*

## Node
node_modules/
