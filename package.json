{
  "name": "zenn-dev",
  "version": "1.0.2",
  "description": "zenn.dev articles repo",
  "author": "Furukawa, Atsushi <atsushifx@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atsushifx/zenn-dev.git"
  },
  "scripts": {
    "prepare": "bash ./scripts/setup-dev-env.sh",
    "scan:secrets": "gitleaks dir --config ./configs/gitleaks.toml . && secretlint --secretlintrc ./configs/secretlint.config.yaml **/*",
    "format:dprint": "dprint fmt",
    "check:dprint": "dprint check",
    "check:spells": "cspell  --config .vscode/cspell.json --cache --cache-location .cache/cspell/cSpellCache",
    "lint:text": "pnpm exec textlint --config ./configs/textlintrc.yaml --cache --cache-location .cache/textlintCache ",
    "lint:markdown": "pnpm exec markdownlint-cli2 --config ./configs/.markdownlint-cli2.yaml "
  },
  "devDependencies": {
    "zenn-cli": "^0.4.6"
  }
}
